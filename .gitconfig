[user]
  name = "Jerry Augusto"
  email = "47633560+jerryaugusto@users.noreply.github.com"

# INCLUDES
# --------
# Local/Private config goes in the include
[include]
  path = ~/.gitconfig.local
# URL ALIASES
# -----------
# Alias for Dracula Org repositories
[url "https://github.com/dracula/"]
  insteadOf = dracula://
# COLORS
# ------
# Dracula Dark Theme
[color]
  ui = auto
[color "branch"]
  current = cyan bold reverse
  local = white
  plain =
  remote = cyan
[color "diff"]
  commit =
  func = cyan
  plain =
  whitespace = magenta reverse
  meta = white
  frag = cyan bold reverse
  old = red
  new = green
[color "grep"]
  context =
  filename =
  function =
  linenumber = white
  match =
  selected =
  separator =
[color "interactive"]
  error =
  header =
  help =
  prompt =
[color "status"]
  added = green
  changed = yellow
  header =
  localBranch =
  nobranch =
  remoteBranch = cyan bold
  unmerged = magenta bold reverse
  untracked = red
  updated = green bold
[core]
	excludesfile = /home/jerryaugusto/.gitignore_global

; [user]
; 	signingkey = D1B8D764EF69AA3D!

[commit]
	gpgsign = false

